<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تطبيق المعلم"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#4F46E5"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نظام البث المحلي Offline"
            android:textSize="12sp"
            android:textColor="#1E293B" />
    </LinearLayout>

    <!-- حالة السيرفر -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#4F46E5"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/serverStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ جاري تشغيل الرادار..."
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/connectedCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👥 الطلاب المتصلون: 0"
            android:textSize="14sp"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐 IP: 192.168.43.1:8080"
            android:textSize="12sp"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <!-- إرشادات -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📚 إرشادات للمعلم"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#4F46E5"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. افتح الإعدادات ← نقطة اتصال محمولة (Hotspot)"
            android:textSize="12sp"
            android:textColor="#1E293B"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. شغّل نقطة البث يدوياً"
            android:textSize="12sp"
            android:textColor="#1E293B"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3. أخبر الطلاب بالاتصال بنفس الشبكة"
            android:textSize="12sp"
            android:textColor="#1E293B"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4. الطلاب يتصلون بـ ws://192.168.43.1:8080"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#4F46E5" />

    </LinearLayout>

    <!-- زر البث -->
    <Button
        android:id="@+id/broadcastButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📢 بث درس جديد"
        android:textSize="14sp"
        android:textStyle="bold"
        android:backgroundTint="#4F46E5"
        android:layout_marginBottom="16dp" />

</LinearLayout>
